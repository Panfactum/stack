---
interface Props {
  version: string;
}

const { version } = Astro.props;
const jsonHref = `/docs/${version}/reference/glossary.json`;
const btnClass = "flex items-center justify-center rounded-md border border-primary bg-tertiary px-2 py-1 text-secondary !no-underline hover:bg-secondary hover:text-primary";
---

<div class="float-right flex items-center gap-2">
  <a href={jsonHref} title="View as JSON" class={btnClass}>
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 4a2 2 0 0 0-2 2v3a2 3 0 0 1-2 3 2 3 0 0 1 2 3v3a2 2 0 0 0 2 2M17 4a2 2 0 0 1 2 2v3a2 3 0 0 0 2 3 2 3 0 0 0-2 3v3a2 2 0 0 1-2 2"/></svg>
  </a>
</div>
