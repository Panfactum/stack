#################################################
## Base Image
#################################################
FROM node:20-bullseye-slim AS base
WORKDIR /code

#################################################
## Dependencies Image
#################################################
FROM base AS deps

RUN npm i -g pnpm@9.14.2

COPY packages/reference-typescript/package.json packages/reference-typescript/pnpm-lock.yaml packages/reference-typescript/.npmrc ./
RUN --mount=type=cache,id=pnpm-demo-user-service,target=/code/.pnpm-store \
    pnpm install --frozen-lockfile

#################################################
## Builder Image
#################################################

FROM deps AS builder
ENV NODE_ENV=production
COPY packages/reference-typescript/tsconfig.json ./
COPY packages/reference-typescript/src ./src
RUN npx ncc build src/main.ts -o dist

#################################################
## Production Image
#################################################

FROM base AS production
ENV NODE_ENV=production
COPY --from=builder /code/dist ./
