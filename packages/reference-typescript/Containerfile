#################################################
## Base Image
#################################################
FROM node:20-bullseye-slim AS base
WORKDIR /code

#################################################
## Dependencies Image
#################################################
FROM base AS deps

# Install package manager
RUN npm i -g pnpm@9.14.2

# Install Dependencies (workspace lockfile lives at the repo root)
COPY package.json pnpm-lock.yaml .npmrc pnpm-workspace.yaml ./
COPY packages/website/package.json packages/website/
COPY packages/scraper/package.json packages/scraper/
COPY packages/reference-typescript/package.json packages/reference-typescript/
RUN --mount=type=cache,id=pnpm,target=/code/.pnpm pnpm install --frozen-lockfile --filter demo-user-service

#################################################
## Development Image
#################################################

FROM deps AS development
WORKDIR /code/packages/reference-typescript
COPY packages/reference-typescript/ .
RUN npx ncc build src/main.ts -o dist

#################################################
## Builder Image
#################################################

FROM deps AS builder
ENV NODE_ENV=production
WORKDIR /code/packages/reference-typescript
COPY packages/reference-typescript/ .
RUN npx ncc build src/main.ts -o dist

#################################################
## Production Image
#################################################

FROM base AS production
ENV NODE_ENV=production
WORKDIR /code/packages/reference-typescript
COPY --from=builder /code/packages/reference-typescript/dist ./
