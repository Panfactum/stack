#################################################
## Base Image
#################################################
FROM oven/bun:1.2.5-slim AS base
WORKDIR /code

#################################################
## Dependencies Image
#################################################
FROM base AS deps

# Copy the scraper's package files for dependency installation.
# Copy the least-changing files first so layer caching survives source edits.
COPY packages/scraper/package.json packages/scraper/bun.lock packages/scraper/bunfig.toml ./

# --production drops devDependencies (typescript, @types/node) since bun runs
# TypeScript natively. The cache mount preserves bun's tarball cache across
# builds via the BuildKit S3 cache backend, so reinstalls are essentially free.
RUN --mount=type=cache,id=bun-scraper,target=/code/.bun \
    bun install --frozen-lockfile --production

#################################################
## Production Image
#################################################
FROM base AS production
ENV NODE_ENV=production

# COPY --link makes each layer content-addressable so they can be cached
# independently of preceding layers. Layers are listed most-stable first
# so source edits only invalidate the final layer.
COPY --link --from=deps /code/node_modules ./node_modules
COPY --link packages/scraper/package.json packages/scraper/tsconfig.json ./
COPY --link packages/scraper/src ./src

CMD ["bun", "run", "src/main.ts"]
